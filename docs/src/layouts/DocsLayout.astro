---
import TableOfContents from '../components/TableOfContents.astro';
import SearchModal from '../components/SearchModal.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description = 'Engineering documentation for Pocket Gull — a voice-first clinical co-pilot.', headings = [] } = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/docs/', label: 'Overview' },
  { href: '/docs/architecture', label: 'Architecture' },
  { href: '/docs/features', label: 'Features' },
  { href: '/docs/data', label: 'Data & Privacy' },
  { href: '/docs/security', label: 'Security & Compliance' },
  { href: '/docs/responsible-ai', label: 'Responsible AI' },
  { href: '/docs/getting-started', label: 'Getting Started' },
  { href: '/docs/study', label: 'Case Study' },
  { href: '/docs/changelog', label: 'Changelog' },
];

function isActive(href: string): boolean {
  const clean = currentPath.replace(/\/$/, '') || '/';
  const cleanHref = href.replace(/\/$/, '') || '/';
  return clean === cleanHref;
}

// Prev/next page
const currentIndex = navItems.findIndex(item => isActive(item.href));
const prevPage = currentIndex > 0 ? navItems[currentIndex - 1] : null;
const nextPage = currentIndex < navItems.length - 1 ? navItems[currentIndex + 1] : null;

// Version info
const versions = [
  { label: 'v0.2.0', tag: 'latest', current: true },
  { label: 'v0.1.0', tag: 'legacy', current: false },
  { label: 'v0.0.1', tag: 'alpha', current: false },
];

const envGeminiKey = import.meta.env.GEMINI_API_KEY || import.meta.env.PUBLIC_GEMINI_API_KEY || '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Pocket Gull Docs</title>
  <link rel="icon"
    href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><polygon points=%2250,40 65,15 58,45%22 fill=%22%23d0d0d0%22 stroke=%22%23b0b0b0%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon><polygon points=%2220,50 50,40 10,35%22 fill=%22%23e0e0e0%22 stroke=%22%23d0d0d0%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon><polygon points=%2220,50 50,40 58,45 75,55 50,65%22 fill=%22%23f4f4f4%22 stroke=%22%23e0e0e0%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon><polygon points=%2250,40 58,45 35,85%22 fill=%22%23ffffff%22 stroke=%22%23f0f0f0%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon><polygon points=%2250,40 35,85 20,50%22 fill=%22%23f9f9f9%22 stroke=%22%23e0e0e0%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon><polygon points=%2275,55 58,45 85,38%22 fill=%22%23ffffff%22 stroke=%22%23f0f0f0%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon><polygon points=%2285,38 82,45 95,34%22 fill=%22%23ff4500%22 stroke=%22%23df3d00%22 stroke-width=%220.5%22 stroke-linejoin=%22round%22></polygon></svg>" />
  <script is:inline>
    (function() {
      try {
        const theme = localStorage.getItem('pocket_gull_theme') || 'system';
        if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <!-- Top Navbar -->
  <nav class="docs-nav">
    <div class="nav-inner">
      <div class="nav-left">
        <button class="menu-toggle" id="menuToggle" aria-label="Toggle navigation">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a href="/docs/" class="nav-brand" aria-label="Pocket Gull Docs Home">
          <svg aria-hidden="true" width="28" height="28" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="shrink-0"><polygon points="50,40 65,15 58,45" fill="#d0d0d0" stroke="#b0b0b0" stroke-width="0.5" stroke-linejoin="round"></polygon><polygon points="20,50 50,40 10,35" fill="#e0e0e0" stroke="#d0d0d0" stroke-width="0.5" stroke-linejoin="round"></polygon><polygon points="20,50 50,40 58,45 75,55 50,65" fill="#f4f4f4" stroke="#e0e0e0" stroke-width="0.5" stroke-linejoin="round"></polygon><polygon points="50,40 58,45 35,85" fill="#ffffff" stroke="#f0f0f0" stroke-width="0.5" stroke-linejoin="round"></polygon><polygon points="50,40 35,85 20,50" fill="#f9f9f9" stroke="#e0e0e0" stroke-width="0.5" stroke-linejoin="round"></polygon><polygon points="75,55 58,45 85,38" fill="#ffffff" stroke="#f0f0f0" stroke-width="0.5" stroke-linejoin="round"></polygon><polygon points="85,38 82,45 95,34" fill="#ff4500" stroke="#df3d00" stroke-width="0.5" stroke-linejoin="round"></polygon></svg>
          <span class="brand-text" aria-hidden="true">POCKET GULL</span>
          <span class="brand-divider" aria-hidden="true"></span>
          <span class="brand-label" aria-hidden="true">DOCS</span>
        </a>
        <!-- Version Dropdown -->
        <div class="version-dropdown" id="versionDropdown">
          <button class="version-trigger" id="versionTrigger">
            <span>v0.2.0</span>
            <svg viewBox="0 -960 960 960" fill="currentColor" width="10" height="10"><path d="M480-344 240-584l56-56 184 184 184-184 56 56-240 240Z"/></svg>
          </button>
          <div class="version-menu" id="versionMenu">
            {versions.map(v => (
              <div class:list={['version-item', { active: v.current }]}>
                <span class="version-label">{v.label}</span>
                {v.current && <span class="version-tag">current</span>}
                {!v.current && <span class="version-tag muted">{v.tag}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="nav-links">
        <button id="themeToggleBtn" aria-label="Toggle Theme" title="Theme: system" style="background:none; border:none; cursor:pointer; color:var(--pg-text-muted); padding: 8px; min-height: 44px; min-width: 44px; display:flex; justify-content:center; align-items:center; transition: color 0.2s;" onmouseover="this.style.color='var(--pg-text)'" onmouseout="this.style.color='var(--pg-text-muted)'">
           <svg id="themeIconDark" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>   
           <svg id="themeIconLight" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
           <svg id="themeIconSystem" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
        <button id="searchTrigger" class="nav-search-btn">
          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <span class="search-text">Search</span>
          <kbd class="shortcut">⌘K</kbd>
        </button>
        <a href="https://pocketgull.app" target="_blank" rel="noopener">Live App ↗</a>
        <a href="https://github.com/philgear/pocketgull" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </nav>

  <div class="docs-container">
    <!-- Sidebar -->
    <aside class="docs-sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <div class="sidebar-section-label">Documentation</div>
        {navItems.map((item) => (
          <a href={item.href} class:list={['sidebar-link', { active: isActive(item.href) }]}>
            {item.label}
          </a>
        ))}
      </nav>
      <div class="sidebar-footer">
        <span>v0.2.0</span>
        <span>·</span>
        <span>MIT</span>
      </div>
    </aside>

    <!-- Content -->
    <main class="docs-main">
      <div class="docs-content-wrapper">
        <div class="docs-article-wrapper">
          <article class="docs-article">
            <slot />
          </article>

          <!-- Prev / Next Navigation -->
          <nav class="page-nav">
            {prevPage ? (
              <a href={prevPage.href} class="page-nav-card page-nav-prev">
                <span class="page-nav-direction">← Previous</span>
                <span class="page-nav-label">{prevPage.label}</span>
              </a>
            ) : <div></div>}
            {nextPage ? (
              <a href={nextPage.href} class="page-nav-card page-nav-next">
                <span class="page-nav-direction">Next →</span>
                <span class="page-nav-label">{nextPage.label}</span>
              </a>
            ) : <div></div>}
          </nav>
        </div>

        {headings.length > 0 && (
          <aside class="docs-toc-container">
            <TableOfContents headings={headings} />
          </aside>
        )}
      </div>

      <footer class="docs-footer" style="display:flex; justify-content:space-between; align-items:center;">
        <p style="margin:0;">© 2026 Phil Gear · <a href="https://g.dev/philgear" style="color:var(--pg-text); text-decoration:underline;">g.dev/philgear</a> · MIT License</p>
        <a href="https://github.com/philgear/pocketgull" target="_blank" rel="noopener" style="color:var(--pg-text-muted); transition:color 0.15s;" title="View Source on GitHub" onmouseover="this.style.color='var(--pg-text)'" onmouseout="this.style.color='var(--pg-text-muted)'">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
        </a>
      </footer>
    </main>
  </div>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menuToggle');
    const sidebar = document.getElementById('sidebar');
    toggle?.addEventListener('click', () => {
      sidebar?.classList.toggle('open');
    });
    sidebar?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => sidebar?.classList.remove('open'));
    });

    // Version dropdown
    const versionTrigger = document.getElementById('versionTrigger');
    const versionMenu = document.getElementById('versionMenu');
    versionTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      versionMenu?.classList.toggle('open');
    });
    document.addEventListener('click', () => {
      versionMenu?.classList.remove('open');
    });

    // TOC Active State logic via Intersection Observer
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-link').forEach((link) => link.classList.remove('active'));
            const id = entry.target.getAttribute('id');
            const newLink = document.querySelector(`.toc-link[href="#${id}"]`);
            if (newLink) newLink.classList.add('active');
          }
        });
      },
      { rootMargin: '-10% 0px -80% 0px' }
    );
    document.querySelectorAll('h2[id], h3[id]').forEach((section) => observer.observe(section));

    // Theme logic
    const themeBtn = document.getElementById('themeToggleBtn');
    const iconDark = document.getElementById('themeIconDark');
    const iconLight = document.getElementById('themeIconLight');
    const iconSystem = document.getElementById('themeIconSystem');

    let currentTheme = localStorage.getItem('pocket_gull_theme') || 'system';

    function applyThemeIcon() {
      if(!themeBtn) return;
      iconDark.style.display = 'none';
      iconLight.style.display = 'none';
      iconSystem.style.display = 'none';
      
      if (currentTheme === 'dark') {
        iconDark.style.display = 'block';
        document.documentElement.setAttribute('data-theme', 'dark');
      } else if (currentTheme === 'light') {
        iconLight.style.display = 'block';
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        iconSystem.style.display = 'block';
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
           document.documentElement.setAttribute('data-theme', 'dark');
        } else {
           document.documentElement.setAttribute('data-theme', 'light');
        }
      }
      themeBtn.title = 'Theme: ' + currentTheme;
    }

    applyThemeIcon();

    themeBtn?.addEventListener('click', () => {
      if (currentTheme === 'system') currentTheme = 'light';
      else if (currentTheme === 'light') currentTheme = 'dark';
      else currentTheme = 'system';
      
      localStorage.setItem('pocket_gull_theme', currentTheme);
      applyThemeIcon();
    });
  </script>

  <!-- Environment variable injection -->
  <script is:inline define:vars={{ envGeminiKey }}>
    window.PG_DOCS_ENV_KEY = envGeminiKey;
  </script>
  <!-- DocNode drill-down engine -->
  <script is:inline src="/docs/scripts/doc-drill.js"></script>
  
  <SearchModal />
  
  <!-- Mermaid.js Intercept -->
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
    
    document.querySelectorAll('pre[data-language="mermaid"]').forEach(pre => {
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.style.display = 'flex';
      div.style.justifyContent = 'center';
      div.style.margin = '2rem 0';
      
      // Astro's Shiki highlighter drops \n characters between .line spans, causing Mermaid syntax errors.
      const lines = pre.querySelectorAll('.line');
      if (lines.length > 0) {
        div.textContent = Array.from(lines).map(l => l.textContent).join('\n');
      } else {
        div.textContent = pre.textContent;
      }
      
      pre.replaceWith(div);
    });

    mermaid.initialize({ 
      startOnLoad: false, 
      theme: 'base',
      themeVariables: {
        background: 'transparent',
        primaryColor: 'var(--pg-surface)',
        primaryBorderColor: 'var(--pg-border)',
        primaryTextColor: 'var(--pg-text)',
        secondaryColor: 'var(--pg-bg)',
        tertiaryColor: 'var(--pg-surface)',
        lineColor: 'var(--pg-text-muted)',
        edgeLabelBackground: 'var(--pg-surface)',
        fontFamily: "'Inter', system-ui, sans-serif",
        fontSize: '13px',
        clusterBkg: 'var(--pg-bg)',
        clusterBorder: 'var(--pg-border)',
        titleColor: 'var(--pg-text)',
        textColor: 'var(--pg-text-muted)'
      }
    });

    await mermaid.run({
      querySelector: '.mermaid',
    });
  </script>

  <!-- Copy-to-Clipboard Intercept -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('pre').forEach((pre) => {
        if (pre.getAttribute('data-language') === 'mermaid') return;

        const container = document.createElement('div');
        container.className = 'code-block-container';
        pre.parentNode.insertBefore(container, pre);
        container.appendChild(pre);

        const button = document.createElement('button');
        button.className = 'copy-btn';
        button.ariaLabel = 'Copy code to clipboard';
        button.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        
        button.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.innerText || pre.innerText;
          try {
            await navigator.clipboard.writeText(code);
            button.classList.add('copied');
            button.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            setTimeout(() => {
              button.classList.remove('copied');
              button.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
            }, 2000);
          } catch (err) {
            console.error('Failed to copy', err);
          }
        });
        container.appendChild(button);
      });
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/doc-nodes.css';

  .code-block-container {
    position: relative;
    margin: 1.5rem 0;
  }
  .code-block-container pre {
    margin: 0 !important;
  }
  .copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--pg-surface);
    border: 1px solid var(--pg-border);
    color: var(--pg-text-muted);
    border-radius: 6px;
    padding: 6px;
    cursor: pointer;
    opacity: 0;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .code-block-container:hover .copy-btn {
    opacity: 1;
  }
  .copy-btn:hover {
    color: var(--pg-text);
    border-color: var(--pg-accent);
  }
  .copy-btn.copied {
    color: #689F38;
    border-color: #689F38;
    background: #F0F7E8;
  }
</style>

<style>
  .docs-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    height: 56px;
    border-bottom: 1px solid var(--pg-border);
    background: var(--pg-surface);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--pg-text-muted);
    cursor: pointer;
    padding: 0.25rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--pg-text);
  }

  .nav-brand:hover { text-decoration: none; }

  .brand-text {
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--pg-text);
  }

  .brand-divider {
    width: 1px;
    height: 16px;
    background: var(--pg-border);
  }

  .brand-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--pg-text-muted);
    text-transform: uppercase;
  }

  /* Version Dropdown */
  .version-dropdown {
    position: relative;
    margin-left: 0.25rem;
  }

  .version-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--pg-text-muted);
    background: var(--pg-bg);
    border: 1px solid var(--pg-border);
    border-radius: 4px;
    padding: 3px 8px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .version-trigger:hover {
    border-color: var(--pg-accent);
    color: var(--pg-text);
  }

  .version-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 140px;
    background: var(--pg-surface);
    border: 1px solid var(--pg-border);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
    z-index: 60;
    display: none;
    padding: 4px;
  }

  .version-menu.open { display: block; }

  .version-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: background 0.12s;
  }

  .version-item:hover { background: var(--pg-border); }
  .version-item.active { font-weight: 600; }

  .version-label { color: var(--pg-text); }

  .version-tag {
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #689F38;
    background: #F0F7E8;
    border: 1px solid #C8E6C9;
    border-radius: 8px;
    padding: 1px 5px;
  }

  .version-tag.muted {
    color: #9CA3AF;
    background: #F3F4F6;
    border-color: #E5E7EB;
